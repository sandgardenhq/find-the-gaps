{{ .Summary }}

## Features

{{ range .Features -}}
<div class="ftg-feature-card {{ if .Documented }}ftg-feature-card--documented{{ else }}ftg-feature-card--undocumented{{ end }}">

### {{ .Name }}

<div class="ftg-badges">
{{- if .Layer }}<span class="ftg-badge ftg-badge--layer">{{ .Layer }}</span>{{ end -}}
{{- if .UserFacing }}<span class="ftg-badge ftg-badge--user-facing">user-facing</span>{{ else }}<span class="ftg-badge ftg-badge--internal">internal</span>{{ end -}}
{{- if .Documented }}<span class="ftg-badge ftg-badge--documented">documented</span>{{ else }}<span class="ftg-badge ftg-badge--undocumented">undocumented</span>{{ end -}}
</div>

{{ if .Description }}> {{ .Description }}

{{ end -}}
{{ if .Files -}}
<details class="ftg-collapse ftg-collapse--files"><summary>Implemented in ({{ len .Files }})</summary>

{{ range .Files }}- `{{ . }}`
{{ end }}
</details>

{{ end -}}
{{ if .Symbols -}}
<details class="ftg-collapse ftg-collapse--symbols"><summary>Symbols ({{ len .Symbols }})</summary>

{{ range .Symbols }}- `{{ . }}`
{{ end }}
</details>

{{ end -}}
{{ if .DocURLs -}}
<details class="ftg-collapse ftg-collapse--docs"><summary>Documented on ({{ len .DocURLs }})</summary>

{{ range .DocURLs }}- <a href="{{ . | html }}" target="_blank" rel="noopener">{{ . | html }}</a>
{{ end }}
</details>

{{ else -}}

# Verify analyze prints the scan summary with per-layer skip counts when the
# embedded defaults skip a file. package-lock.json is in the curated defaults.
exec ftg analyze --repo repo --cache-dir $WORK/cache
stdout '^scanned 1 files, skipped 1 \(defaults: 1\)$'

-- repo/main.go --
package main

func main() {}
-- repo/package-lock.json --
{}

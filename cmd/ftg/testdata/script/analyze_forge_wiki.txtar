# A wiki URL halts non-zero with the standard halt message even when --repo
# matches the parent repo's origin. v1 does not crawl wikis.

mkdir repo
cd repo
exec git init -q
exec git -c user.email=a@b -c user.name=a commit --allow-empty -q -m init
exec git remote add origin https://github.com/foo/bar.git
cd ..

! exec ftg analyze --repo repo --docs https://github.com/foo/bar/wiki --cache-dir $WORK/cache --no-site
stderr 'Find the Gaps can.t crawl source-control forges'

# analyze accepts the default invocation (screenshot check off, experimental,
# opt-in via --experimental-check-screenshots). --docs-url is required, so
# the run fails after scanning; the scan summary still prints first.
mkdir repo
! exec ftg analyze --repo repo --cache-dir $WORK/cache --docs-url https://docs.example.invalid
stdout 'scanned 1 files'

-- repo/main.go --
package main
